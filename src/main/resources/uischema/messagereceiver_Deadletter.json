{
  "connectorName": "asb",
  "operationName": "MessageReceiver_deadLetter",
  "title": "dead letter",
  "help": "Dead-Letter the message & moves the message to the Dead-Letter Queue based on messageLockToken. Transfer \nthe message from the primary queue into a special \"dead-letter sub-queue\".\n",
  "elements": [
    {
      "type": "attributeGroup",
      "value": {
        "groupName": "General",
        "elements": [
          {
            "type": "attribute",
            "value": {
              "name": "configRef",
              "displayName": "Connection",
              "inputType": "connection",
              "allowedConnectionTypes": [
                "asb_MessageReceiver"
              ],
              "defaultType": "connection.asb_MessageReceiver",
              "defaultValue": "",
              "required": "true",
              "helpTip": "Connection to be used"
            }
          },
          {
            "type": "attributeGroup",
            "value": {
              "groupName": "Input Variables",
              "elements": [
                {
                  "type": "attribute",
                  "value": {
                    "name": "sequenceNumber",
                    "displayName": "Sequence Number",
                    "inputType": "stringOrExpression",
                    "defaultValue": "",
                    "required": true,
                    "helpTip": "Sequence number of the message",
                    "validateType": "number"
                  }
                },
                {
                  "type": "attribute",
                  "value": {
                    "name": "deadLetterReason",
                    "displayName": "deadLetterReason",
                    "inputType": "stringOrExpression",
                    "defaultValue": "DEADLETTERED_BY_RECEIVER",
                    "required": false,
                    "helpTip": "",
                    "validateType": "",
                    "matchPattern": ""
                  }
                },
                {
                  "type": "attribute",
                  "value": {
                    "name": "deadLetterErrorDescription",
                    "displayName": "deadLetterErrorDescription",
                    "inputType": "stringOrExpression",
                    "defaultValue": "",
                    "required": false,
                    "helpTip": "",
                    "validateType": "",
                    "matchPattern": ""
                  }
                }
              ]
            }
          },
          {
            "type": "attributeGroup",
            "value": {
              "groupName": "Output",
              "elements": [
                {
                  "type": "attribute",
                  "value": {
                    "name": "responseVariable",
                    "displayName": "Output Variable Name",
                    "inputType": "string",
                    "defaultValue": "",
                    "required": "false",
                    "helpTip": "The target variable in which the output of the operation will be stored"
                  }
                },
                {
                  "type": "attribute",
                  "value": {
                    "name": "overwriteBody",
                    "displayName": "Overwrite Message Body",
                    "inputType": "checkbox",
                    "defaultValue": "false",
                    "helpTip": "Replace the Message Body in Message Context with the output payload of the operation (This will remove the payload from the above variable. But other elements such as headers and attributes will remain).",
                    "required": "false"
                  }
                }
              ]
            }
          }
        ]
      }
    }
  ]
