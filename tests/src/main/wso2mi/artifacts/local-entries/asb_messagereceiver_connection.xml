<?xml version="1.0" encoding="UTF-8"?>
<localEntry key="asb_messagereceiver_connection" xmlns="http://ws.apache.org/ns/synapse">
  <asb.init>
    <connectionType>ASB_MESSAGERECEIVER</connectionType>
    <connectionString>{${configs.connection_string}}</connectionString>
    <entityConfigDataType>TopicSubsConfig</entityConfigDataType>
    <entityConfig_topicName>{${configs.topic_name}}</entityConfig_topicName>
    <entityConfig_subscriptionName>{${configs.subscription_name}}</entityConfig_subscriptionName>
