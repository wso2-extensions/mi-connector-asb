    <enable_amqpRetryOptions>false</enable_amqpRetryOptions>
    <amqpRetryOptions_retryMode>EXPONENTIAL</amqpRetryOptions_retryMode>
    <name>asb_messagereceiver_connection</name>
  </asb.init>
</localEntry>